#!/usr/bin/env bash
# e156 -- single-command wrapper for the ecosystem-starter UX.
#
# Subcommands:
#   e156 start               Launch Gemini CLI with the handoff prompt loaded
#   e156 start --claude      Same, but with Claude Code instead
#   e156 version             Print the installed ecosystem-starter version
#   e156 help                Show this help
#
# Why this exists: the prior UX asked non-coder students to type
#   cat ~/.config/e156/handoff.md
# then paste into `gemini`. That's three concepts (cat, ~, paste-into-cli)
# a first-year medical student has never seen. This wrapper collapses it
# to one word: `e156 start`. P0-U1 from the 2026-04-27 user-POV review.

set -u

prompt_file="${HOME}/.config/e156/handoff.md"

cmd_help() {
    cat <<'HELP'
e156 -- one-command wrapper for the E156 ecosystem starter

Usage:
  e156 start            Launch Gemini CLI (free) with the handoff briefing
  e156 start --claude   Launch Claude Code instead (needs ANTHROPIC_API_KEY)
  e156 version          Print installed version
  e156 help             Show this help

The handoff briefing is at ~/.config/e156/handoff.md
HELP
}

cmd_version() {
    # Resolve installed version, in order of confidence:
    #   1. The recorded ref file (written by on-create.sh / installer)
    #   2. git describe in the actual codespace working dir
    #   3. git describe in a local-install candidate dir
    #   4. The installed-ref file's content even if empty (so user sees
    #      what's there)
    # P1-V3 from review: prior implementation almost always returned
    # "unknown" because shallow Codespace clones break `git describe`
    # in the codespace path that wasn't being checked.
    local pinned="${HOME}/.config/e156/installed-ref"
    if [[ -f "$pinned" ]] && [[ -s "$pinned" ]]; then
        cat "$pinned"
        return 0
    fi
    # Try the codespace working directory first (it's the most-likely path
    # in a Codespaces install) before the local-install candidate.
    for candidate in "/workspaces/e156-ecosystem-starter" "${HOME}/code/e156-ecosystem-starter"; do
        if [[ -d "$candidate/.git" ]] && command -v git >/dev/null 2>&1; then
            local v
            v="$(cd "$candidate" && { git describe --tags --always 2>/dev/null || git rev-parse --short HEAD 2>/dev/null; })"
            if [[ -n "$v" ]]; then printf '%s\n' "$v"; return 0; fi
        fi
    done
    echo "unknown (no recorded ref and no readable git working dir)"
    return 1
}

cmd_start() {
    # Args parsing — getopts-style. P2-V2 from review.
    local agent="gemini"
    local opt
    while [[ "${1:-}" == --* ]]; do
        opt="$1"; shift
        case "$opt" in
            --claude)  agent="claude" ;;
            --gemini)  agent="gemini" ;;
            -h|--help) cmd_help; return 0 ;;
            *) echo "Unknown flag: $opt" >&2; cmd_help >&2; return 2 ;;
        esac
    done

    if [[ ! -f "$prompt_file" ]]; then
        echo "ERROR: handoff prompt not found at $prompt_file" >&2
        echo "       Re-run the ecosystem installer to regenerate it." >&2
        return 1
    fi

    # Agent-CLI-missing handling. P1-V2 from review: the prior "Install:
    # npm install -g ..." message was a CLI command — exactly the cliff
    # the wrapper was designed to remove. Now: offer to run the install
    # ourselves with one prompt, OR redirect to the bootstrap re-run.
    if ! command -v "$agent" >/dev/null 2>&1; then
        echo "The '$agent' command is not available on this machine."
        echo
        if [[ -f /.dockerenv ]] || [[ -n "${CODESPACES:-}" ]]; then
            # Codespace context: the install should have done this. Offer recovery.
            echo "This codespace's install did not complete the agent-CLI step."
            echo "Easiest fix: rebuild the codespace (Codespaces menu -> Rebuild Container)."
            echo "Or, to install just '$agent' now, type Y and press Enter:"
            read -r -p "  Install $agent now? [Y/n] " ans
            case "${ans:-Y}" in
                [Yy]*|"") ;;
                *) echo "Skipped. Run 'e156 start' again after you install $agent."; return 1 ;;
            esac
            local pkg
            if [[ "$agent" == "gemini" ]]; then pkg="@google/gemini-cli@^0.39.0"
            else                                pkg="@anthropic-ai/claude-code@~2.1.0"; fi
            if command -v npm >/dev/null 2>&1; then
                npm install -g "$pkg" || { echo "npm install failed." >&2; return 1; }
            else
                echo "ERROR: npm not on PATH; cannot install $agent." >&2
                return 1
            fi
        else
            # Local install: don't offer to install (we don't know their
            # package manager); point them back to the bootstrap.
            echo "On a local install, the easiest recovery is to re-run the bootstrap"
            echo "one-liner from https://mahmood726-cyber.github.io/e156-ecosystem-starter/"
            echo "which will install '$agent' as part of the chain."
            return 1
        fi
    fi

    # Copy-prompt-to-clipboard + open-agent-interactive pattern.
    # P0-V2 from review: piping the prompt as stdin to gemini/claude is
    # NOT a documented contract for "first user message in interactive
    # session" — for both CLIs, stdin tends to mean non-interactive
    # one-shot mode. Robust pattern: copy to clipboard, open the agent
    # in its normal interactive mode, tell the student to paste.
    local clipboard_tool=""
    for tool in pbcopy wl-copy "xclip -selection clipboard" xsel; do
        local cmd="${tool%% *}"
        if command -v "$cmd" >/dev/null 2>&1; then clipboard_tool="$tool"; break; fi
    done

    if [[ -n "$clipboard_tool" ]]; then
        # shellcheck disable=SC2086  # intentional word-split for tool args
        eval "$clipboard_tool" < "$prompt_file" 2>/dev/null && copied=1 || copied=0
    else
        copied=0
    fi

    echo "==> Launching $agent with the E156 handoff briefing..."
    if [[ "$copied" == "1" ]]; then
        echo "    Briefing is copied to your clipboard."
        echo "    When $agent's prompt appears, paste it (Ctrl+Shift+V on Linux/Win,"
        echo "    Cmd+V on Mac) and press Enter."
    else
        echo "    Clipboard tool not available. Open the briefing in another tab:"
        echo "      $prompt_file"
        echo "    Then copy/paste it into $agent when it asks."
    fi
    if [[ "$agent" == "gemini" ]]; then
        echo "    First time? $agent will open a browser tab for Google sign-in."
    elif [[ "$agent" == "claude" ]]; then
        echo "    Make sure ANTHROPIC_API_KEY is set in your environment."
    fi
    echo

    # Run interactively; do NOT pipe stdin (that would force one-shot mode
    # in many AI-CLI implementations). Inherit current TTY.
    "$agent"
    return $?
}

case "${1:-help}" in
    start)         shift; cmd_start "$@" ;;
    version|-v|--version)  cmd_version ;;
    help|-h|--help|"")     cmd_help ;;
    *)
        echo "Unknown command: $1" >&2
        cmd_help >&2
        exit 2
        ;;
esac
